<div class="mb-4">
  <%= link_to "← Back to Vets", vets_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-info text-white">
    <h2 class="h4 mb-0 text-dark"><%= @vet.first_name %> <%= @vet.last_name %></h2>
  </div>
  <div class="card-body">
    <p><strong>Email:</strong> <%= @vet.email %></p>
    <p><strong>Phone:</strong> <%= @vet.phone %></p>
    <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
  </div>
</div>

<h3 class="h5 mb-3">Upcoming Appointments</h3>
<div class="list-group mb-4">
  <% @upcoming_appointments.each do |appointment| %>
    <%= link_to appointment_path(appointment), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
      <span>Appointment on <%= appointment.date.strftime('%B %d, %Y') %> with <%= appointment.pet.name %></span>
      <span class="badge bg-primary rounded-pill"><%= appointment.status.titleize %></span>
    <% end %>
  <% end %>
  <% if @upcoming_appointments.empty? %>
    <p class="text-muted mt-2">This veterinarian has no upcoming appointments.</p>
  <% end %>
</div>

<h3 class="h5 mb-3">Past Appointments</h3>
<div class="list-group">
  <% @vet.appointments.past.includes(:pet).each do |appointment| %>
    <%= link_to appointment_path(appointment), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
      <span>Appointment on <%= appointment.date.strftime('%B %d, %Y') %> with <%= appointment.pet.name %></span>
      <span class="badge bg-secondary rounded-pill"><%= appointment.status.titleize %></span>
    <% end %>
  <% end %>
  <% if @vet.appointments.past.empty? %>
    <p class="text-muted mt-2">This veterinarian has no past appointments.</p>
  <% end %>
</div>